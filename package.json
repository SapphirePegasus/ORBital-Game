{
  "name": "orbital-game",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "type-check": "tsc --noEmit",
    "prebuild": "expo prebuild --clean"
  },
  "dependencies": {
    "@shopify/react-native-skia": "^1.3.0",
    "expo": "~51.0.0",
    "expo-av": "~14.0.0",
    "expo-blur": "~13.0.0",
    "expo-dev-client": "~4.0.0",
    "expo-router": "~3.5.0",
    "expo-status-bar": "~1.12.0",
    "immer": "^10.1.1",
    "react": "18.2.0",
    "react-native": "0.74.1",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-mmkv": "^2.12.2",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "3.31.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^12.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.2.0",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.57.0",
    "eslint-config-universe": "^12.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^../assets/audio/(.*)$": "<rootDir>/__mocks__/audioAsset.js",
      "^react-native-mmkv$": "<rootDir>/__mocks__/mmkv.js",
      "^expo-av$": "<rootDir>/__mocks__/expoAv.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@shopify/react-native-skia|react-native-reanimated|zustand|immer)"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/.expo/"
    ]
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}
